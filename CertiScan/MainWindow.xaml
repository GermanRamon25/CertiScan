<Window x:Class="CertiScan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CertiScan"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="CertiScan | Compliance Notarial"
        Height="700" Width="1100" 
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        Background="#F0F2F5">

    <Window.Resources>
        <sys:Boolean x:Key="ValorTrue">True</sys:Boolean>
        <sys:Boolean x:Key="ValorFalse">False</sys:Boolean>

        <SolidColorBrush x:Key="HeaderDark" Color="#213449"/>
        <SolidColorBrush x:Key="MenuHover" Color="#2C4159"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2196F3"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#2E7D32"/>
        <SolidColorBrush x:Key="ErrorRed" Color="#C62828"/>
        <SolidColorBrush x:Key="SatColor" Color="#691C32"/>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#213449"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AprobatoriaStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SuccessGreen}"/>
        </Style>
        <Style x:Key="DenegadaStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="{StaticResource ErrorRed}"/>
        </Style>
        <Style x:Key="EliminarStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#D32F2F"/>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" Background="White" CornerRadius="4">
                            <Grid>
                                <TextBlock x:Name="PlaceholderText" 
                                           Text="{TemplateBinding Tag}" 
                                           Foreground="#70757a" 
                                           FontSize="13"
                                           VerticalAlignment="Center" 
                                           Margin="12,0" 
                                           IsHitTestVisible="False" 
                                           Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="#3E5062" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" 
                                           FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                <TextBlock Grid.Column="1" Text="{TemplateBinding Content}" 
                                           VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                <Rectangle x:Name="Indicator" HorizontalAlignment="Left" Width="4" Fill="Transparent" Height="40"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource MenuHover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A293A"/>
                                <Setter TargetName="Indicator" Property="Fill" Value="{StaticResource PrimaryBlue}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderDark}" Padding="10,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleButton x:Name="SidebarToggle" Width="40" Height="40" Background="Transparent" BorderThickness="0" 
                                  Foreground="White" FontSize="20" Content="☰" Cursor="Hand" Click="SidebarToggle_Click" Margin="0,0,15,0">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent">
                                                <TextBlock Text="☰" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontSize="24"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>

                    <Image Source="/CertiScan;component/Imagenes/CERTISCAN.LOGO.png" Height="35" Margin="0,0,15,0"/>
                    <TextBlock Text="CERTISCAN" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text=" | COMPLIANCE" Foreground="#BBBBBB" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>

                <Grid HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ToggleButton x:Name="UserMenuButton" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border Background="Transparent" Padding="5">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="👤" Foreground="White" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding NombreUsuarioLogueado}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" FontSize="14"/>
                                        <TextBlock Text=" ▾" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                    <Popup x:Name="UserPopup" IsOpen="{Binding IsChecked, ElementName=UserMenuButton}" StaysOpen="False" Placement="Bottom" PlacementTarget="{Binding ElementName=UserMenuButton}" AllowsTransparency="True">
                        <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,5,0,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                            </Border.Effect>
                            <StackPanel Width="220" Margin="10">
                                <TextBlock Text="Sesión activa:" FontSize="11" Foreground="Gray" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding NombreUsuarioLogueado}" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>
                                <Button Content="⚙ Configurar Notaría" Style="{StaticResource ModernButtonStyle}" Background="#213449" Height="30" FontSize="14" Margin="0,0,0,12" Cursor="Hand" Click="ConfigurarNotaria_Click"/>
                                <Separator Margin="0,8" Background="#EEE"/>
                                <Button Content="Cerrar Sesión" Style="{StaticResource ModernButtonStyle}" Background="#D32F2F" Height="30" FontSize="14" Cursor="Hand" Click="LogoutButton_Click"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="Sidebar" Grid.Column="0" Background="#15202B" Width="0" BorderBrush="#2C3E50" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="MÓDULOS" Foreground="#708090" FontSize="11" FontWeight="Bold" Margin="15,10,0,10"/>
                    <RadioButton x:Name="BtnUIF" Content="Búsqueda UIF" Tag="🔍" GroupName="Menu" Style="{StaticResource SidebarButtonStyle}" IsChecked="True" Checked="Menu_Checked"/>
                    <RadioButton x:Name="BtnSAT" Content="Verificación 69-B" Tag="⚖️" GroupName="Menu" Style="{StaticResource SidebarButtonStyle}" Checked="Menu_Checked"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid x:Name="ViewUIF" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="15,15,15,10">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Cargar PDF" Width="120" Height="35" Style="{StaticResource ModernButtonStyle}" Command="{Binding CargarPdfCommand}"/>
                            <TextBox Width="350" Margin="10,0" Style="{StaticResource ModernTextBox}" Tag="Nombre o denominación..." Text="{Binding TerminoBusqueda, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Buscar" Width="100" Height="35" Style="{StaticResource ModernButtonStyle}" Background="{StaticResource PrimaryBlue}" Command="{Binding BuscarCommand}"/>
                            <Button Content="Eliminar PDF" Width="120" Margin="15,0,0,0" Style="{StaticResource EliminarStyle}" Command="{Binding DeletePdfCommand}"/>

                            <Button Content="Ver Historial" Width="120" Margin="15,0,0,0" Style="{StaticResource ModernButtonStyle}" Click="VerHistorial_Click"/>

                            <Button Content="🔄" Width="40" Margin="15,0,0,0" Style="{StaticResource ModernButtonStyle}" Background="Transparent" Foreground="Black" FontSize="18" Command="{Binding RefreshCommand}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="15,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid Grid.Column="0" ItemsSource="{Binding DocumentosMostrados}" SelectedItem="{Binding SelectedDocumento}" AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderBrush="#DDDDDD" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Archivo" Binding="{Binding NombreArchivo}" Width="*"/>
                                <DataGridTextColumn Header="Fecha" Binding="{Binding FechaCarga, StringFormat='dd/MM/yyyy'}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="#E0E0E0" VerticalAlignment="Stretch"/>

                        <Border Grid.Column="2" Background="White" BorderBrush="#DDDDDD" BorderThickness="1" Margin="5,0,0,0">
                            <Grid>
                                <TextBlock Text="Seleccione un documento para visualizar." 
                                           Foreground="DarkGray" FontStyle="Italic" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedDocumento}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="25">
                                    <ScrollViewer.Style>
                                        <Style TargetType="ScrollViewer">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedDocumento}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ScrollViewer.Style>

                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedDocumento.NombreArchivo}" FontSize="20" FontWeight="Bold" Foreground="#213449" Margin="0,0,0,10"/>
                                        <Separator Margin="0,0,0,20" Background="#E0E0E0"/>
                                        <TextBox Text="{Binding ContenidoDocumento}" TextWrapping="Wrap" IsReadOnly="True" BorderThickness="0" Background="Transparent" FontSize="15" FontFamily="Segoe UI" Foreground="#333333" AcceptsReturn="True"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" Background="White" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0" Padding="15">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Generar Constancia Aprobatoria" Width="260" Height="45" Style="{StaticResource AprobatoriaStyle}" Margin="0,0,20,0" Command="{Binding GenerarConstanciaCommand}" CommandParameter="{StaticResource ValorTrue}" IsEnabled="{Binding IsAprobatoriaButtonEnabled}"/>
                            <Button Content="Generar Constancia Denegada" Width="260" Height="45" Style="{StaticResource DenegadaStyle}" Command="{Binding GenerarConstanciaCommand}" CommandParameter="{StaticResource ValorFalse}" IsEnabled="{Binding IsDenegadaButtonEnabled}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="ViewSAT" Visibility="Collapsed" Background="#F9F9F9">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="15,15,15,10">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Cargar Listado" Width="130" Height="35" Style="{StaticResource ModernButtonStyle}" Command="{Binding CargarPdfSatCommand}"/>

                            <TextBox Width="350" Margin="10,0" Style="{StaticResource ModernTextBox}" Tag="Buscar RFC o Razón Social..." Text="{Binding TerminoBusquedaSat, UpdateSourceTrigger=PropertyChanged}"/>

                            <Button Content="Buscar" Width="100" Height="35" Style="{StaticResource ModernButtonStyle}" Background="{StaticResource SatColor}" Command="{Binding BuscarSatCommand}"/>
                            <Button Content="Eliminar PDF" Width="120" Margin="15,0,0,0" Style="{StaticResource EliminarStyle}" Command="{Binding DeletePdfSatCommand}"/>

                            <Button Content="Historial 69-B" Width="120" Margin="15,0,0,0" Style="{StaticResource ModernButtonStyle}" Click="VerHistorialSat_Click"/>

                            <Button Content="🔄" Width="40" Margin="15,0,0,0" Style="{StaticResource ModernButtonStyle}" Background="Transparent" Foreground="Black" FontSize="18" Command="{Binding RefreshSatCommand}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="15,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid Grid.Column="0" ItemsSource="{Binding DocumentosSatMostrados}" SelectedItem="{Binding SelectedDocumentoSat}" AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderBrush="#DDDDDD" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Archivo Analizado" Binding="{Binding NombreArchivo}" Width="*"/>
                                <DataGridTextColumn Header="Fecha Análisis" Binding="{Binding FechaCarga, StringFormat='dd/MM/yyyy'}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="#E0E0E0" VerticalAlignment="Stretch"/>

                        <Border Grid.Column="2" Background="White" BorderBrush="#DDDDDD" BorderThickness="1" Margin="5,0,0,0">
                            <Grid>
                                <TextBlock Text="Seleccione un listado para ver el análisis del 69-B." 
                                           Foreground="DarkGray" FontStyle="Italic" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedDocumentoSat}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="25">
                                    <ScrollViewer.Style>
                                        <Style TargetType="ScrollViewer">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedDocumentoSat}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ScrollViewer.Style>

                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedDocumentoSat.NombreArchivo}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource SatColor}" Margin="0,0,0,10"/>
                                        <Separator Margin="0,0,0,20" Background="#E0E0E0"/>

                                        <TextBox Text="{Binding ContenidoDocumentoSat}" TextWrapping="Wrap" IsReadOnly="True" BorderThickness="0" Background="Transparent" FontSize="15" FontFamily="Segoe UI" Foreground="#333333" AcceptsReturn="True"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" Background="White" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0" Padding="15">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Reporte: Sin Coincidencias (Limpio)" 
                                    Width="280" Height="45" 
                                    Style="{StaticResource AprobatoriaStyle}" 
                                    Margin="0,0,20,0" 
                                    Command="{Binding GenerarReporteSatCommand}" 
                                    CommandParameter="{StaticResource ValorTrue}" 
                                    IsEnabled="{Binding IsReporteSatEnabled}"/>

                            <Button Content="Reporte: Con Hallazgos (Detectado)" 
                                    Width="280" Height="45" 
                                    Style="{StaticResource DenegadaStyle}" 
                                    Command="{Binding GenerarReporteSatCommand}" 
                                    CommandParameter="{StaticResource ValorFalse}" 
                                    IsEnabled="{Binding IsReporteSatEnabled}"/>
                        </StackPanel>
                    </Border>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>