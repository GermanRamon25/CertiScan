<Window x:Class="CertiScan.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sw="clr-namespace:System.Windows;assembly=PresentationCore"
        Title="Historial de Búsquedas" Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True" 
        WindowStyle="None"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBlack" Color="#213449"/>
        <SolidColorBrush x:Key="BackgroundGray" Color="#F4F7F9"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#4A90E2"/>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RegenerateButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="16" BorderBrush="#DCDFE3" BorderThickness="1.2">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.1" Color="Black"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal" Margin="10,0">
                                <Border Background="#FEEBEE" CornerRadius="4" Padding="4,2" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="PDF" Foreground="#C62828" FontWeight="Black" FontSize="8" HorizontalAlignment="Center"/>
                                        <Rectangle Fill="#C62828" Height="1" Width="10"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Regenerar" Foreground="#2C3E50" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundGray}" CornerRadius="15" Margin="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="270" Opacity="0.3" ShadowDepth="2"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PrimaryBlack}" CornerRadius="15,15,0,0" Padding="20">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📜" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="HISTORIAL DE BÚSQUEDAS" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right" Foreground="White" Background="Transparent" 
                            BorderThickness="0" FontSize="18" Cursor="Hand" Click="Cerrar_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="20" Padding="15,5" BorderBrush="#DDD" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔍" VerticalAlignment="Center" Margin="5,0,10,0" Opacity="0.5"/>
                            <TextBox Grid.Column="1" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" VerticalAlignment="Center" FontSize="14" Background="Transparent"/>
                        </Grid>
                    </Border>

                    <Button Grid.Column="1" 
                            Content="📊 Exportar CSV" 
                            Margin="15,0,0,0" 
                            Padding="20,0"
                            Height="38"
                            Cursor="Hand"
                            Click="ExportarCSV_Click"
                            Background="{StaticResource AccentBlue}"
                            Foreground="White"
                            FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="19"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <DataGrid x:Name="dgHistorial" Grid.Row="1" 
                          ItemsSource="{Binding FilteredHistorial}"
                          AutoGenerateColumns="False" IsReadOnly="True" SelectionUnit="FullRow" 
                          SelectionMode="Single" CanUserAddRows="False" Background="White"
                          GridLinesVisibility="None" HeadersVisibility="Column" RowHeight="42">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fecha y Hora" Binding="{Binding FechaCarga, StringFormat='dd/MM/yyyy HH:mm'}" Width="150"/>
                        <DataGridTextColumn Header="Usuario" Binding="{Binding NombreUsuario}" Width="120"/>
                        <DataGridTextColumn Header="Término" Binding="{Binding TerminoBuscado}" Width="*"/>
                        <DataGridTemplateColumn Header="Resultado" Width="115">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="ResultBorder" CornerRadius="10" Margin="3" Padding="6,2" HorizontalAlignment="Left">
                                        <TextBlock x:Name="ResultText" Text="{Binding ResultadoTexto}" FontWeight="Bold" FontSize="9"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding ResultadoEncontrado}" Value="True">
                                            <Setter TargetName="ResultBorder" Property="Background" Value="#FFEBEE"/>
                                            <Setter TargetName="ResultText" Property="Foreground" Value="#C62828"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ResultadoEncontrado}" Value="False">
                                            <Setter TargetName="ResultBorder" Property="Background" Value="#E8F5E9"/>
                                            <Setter TargetName="ResultText" Property="Foreground" Value="#2E7D32"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Acción" Width="145">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource RegenerateButtonStyle}"
                                            Command="{Binding DataContext.RegenerateCertificateCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Border>
</Window>